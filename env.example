import React, { useState, useEffect } from 'react';
import { useLanguage } from '../context/LanguageContext';
import { db, handleFirestoreError, OperationType } from '../firebase';
import { collection, query, where, onSnapshot, orderBy, updateDoc, doc, deleteDoc, getDoc, setDoc } from 'firebase/firestore';
import { Workout, UserProfile } from '../types';
import { motion, AnimatePresence } from 'motion/react';
import { BarChart3, Calendar as CalendarIcon, CheckCircle2, Trash2, Flame, Trophy, ChevronLeft, ChevronRight, Dumbbell } from 'lucide-react';

interface ProgressTrackerProps {
  uid: string;
  profile: UserProfile | null;
}

const ProgressTracker: React.FC<ProgressTrackerProps> = ({ uid, profile }) => {
  const { t, language, isRtl } = useLanguage();
  const [workouts, setWorkouts] = useState<Workout[]>([]);
  const [loading, setLoading] = useState(true);
  const [selectedDate, setSelectedDate] = useState(new Date());

  useEffect(() => {
    const q = query(
      collection(db, 'workouts'),
      where('uid', '==', uid),
      orderBy('date', 'desc')
    );

    const unsubscribe = onSnapshot(q, (snapshot) => {
      const workoutData = snapshot.docs.map(doc => ({
        id: doc.id,
        ...doc.data()
      })) as Workout[];
      setWorkouts(workoutData);
      setLoading(false);
    }, (err) => handleFirestoreError(err, OperationType.LIST, 'workouts'));

    return () => unsubscribe();
  }, [uid]);

  const toggleComplete = async (workout: Workout) => {
    try {
      const workoutRef = doc(db, 'workouts', workout.id);
      const newCompleted = !workout.completed;
      const dateCompleted = newCompleted ? new Date().toISOString().split('T')[0] : null;
      
      await updateDoc(workoutRef, {
        completed: newCompleted,
        dateCompleted
      });

      // Update profile stats
      const userRef = doc(db, 'users', uid);
      const userSnap = await getDoc(userRef);
      if (userSnap.exists()) {
        const userData = userSnap.data() as UserProfile;
        const totalSessions = userData.totalSessions || 0;
        const completedSessions = (userData.completedSessions || 0) + (newCompleted ? 1 : -1);
        
        // Simple streak logic
        let currentStreak = userData.currentStreak || 0;
        if (newCompleted) {
          const lastDate = userData.lastWorkoutDate;
          const today = new Date().toISOString().split('T')[0];
          if (lastDate === today) {
            // Already worked out today
          } else {
            currentStreak += 1;
          }
        }

        await updateDoc(userRef, {
          completedSessions,
          currentStreak,
          lastWorkoutDate: newCompleted ? new Date().toISOString().split('T')[0] : userData.lastWorkoutDate
        });
      }
    } catch (err) {
      handleFirestoreError(err, OperationType.UPDATE, 'workouts');
    }
  };

  const deleteWorkout = async (id: string) => {
    try {
      await deleteDoc(doc(db, 'workouts', id));
    } catch (err) {
      handleFirestoreError(err, OperationType.DELETE, 'workouts');
    }
  };

  const getDaysInMonth = (date: Date) => {
    const year = date.getFullYear();
    const month = date.getMonth();
    const firstDay = new Date(year, month, 1).getDay();
    const daysInMonth = new Date(year, month + 1, 0).getDate();
    return { firstDay, daysInMonth };
  };

  const { firstDay, daysInMonth } = getDaysInMonth(selectedDate);
  const days = Array.from({ length: daysInMonth }, (_, i) => i + 1);
  const prevMonthDays = Array.from({ length: firstDay }, (_, i) => i);

  const isWorkoutDay = (day: number) => {
    const dateStr = `${selectedDate.getFullYear()}-${String(selectedDate.getMonth() + 1).padStart(2, '0')}-${String(day).padStart(2, '0')}`;
    return workouts.find(w => w.date === dateStr);
  };

  return (
    <div className="space-y-10">
      <header className="flex items-center gap-4 mb-10">
        <div className="w-12 h-12 bg-[#ff6b35] rounded-2xl flex items-center justify-center shadow-[0_0_20px_rgba(255,107,53,0.2)]">
          <BarChart3 size={24} />
        </div>
        <h1 className="text-4xl font-black tracking-tight">{t('tracker.title')}</h1>
      </header>

      <div className="grid grid-cols-1 lg:grid-cols-3 gap-10">
        {/* Calendar */}
        <div className="lg:col-span-2 bg-[#0a0a0a] border border-white/5 p-8 rounded-[40px] shadow-2xl">
          <div className="flex items-center justify-between mb-8">
            <h2 className="text-2xl font-bold flex items-center gap-3">
              <CalendarIcon className="text-[#ff6b35]" />
              {selectedDate.toLocaleString(language === 'en' ? 'en-US' : 'ar-SA', { month: 'long', year: 'numeric' })}
            </h2>
            <div className="flex gap-2">
              <button 
                onClick={() => setSelectedDate(new Date(selectedDate.setMonth(selectedDate.getMonth() - 1)))}
                className="p-3 bg-white/5 rounded-xl hover:bg-[#ff6b35] transition-all"
              >
                <ChevronLeft size={20} className={isRtl ? 'rotate-180' : ''} />
              </button>
              <button 
                onClick={() => setSelectedDate(new Date(selectedDate.setMonth(selectedDate.getMonth() + 1)))}
                className="p-3 bg-white/5 rounded-xl hover:bg-[#ff6b35] transition-all"
              >
                <ChevronRight size={20} className={isRtl ? 'rotate-180' : ''} />
              </button>
            </div>
          </div>

          <div className="grid grid-cols-7 gap-4">
            {['S', 'M', 'T', 'W', 'T', 'F', 'S'].map(d => (
              <div key={d} className="text-center text-xs font-black text-gray-500 uppercase tracking-widest py-2">{d}</div>
            ))}
            {prevMonthDays.map(i => <div key={`prev-${i}`} />)}
            {days.map(day => {
              const workout = isWorkoutDay(day);
              return (
                <motion.div
                  key={day}
                  whileHover={{ scale: 1.1 }}
                  className={`
                    aspect-square rounded-2xl flex flex-col items-center justify-center relative cursor-pointer transition-all border
                    ${workout 
                      ? workout.completed 
                        ? 'bg-green-500/20 border-green-500/30 text-green-500' 
                        : 'bg-[#ff6b35]/20 border-[#ff6b35]/30 text-[#ff6b35]' 
                      : 'bg-white/5 border-transparent text-gray-500 hover:border-white/20'}
                  `}
                >
                  <span className="text-lg font-bold">{day}</span>
                  {workout && <div className="w-1.5 h-1.5 rounded-full bg-current mt-1" />}
                </motion.div>
              );
            })}
          </div>
        </div>

        {/* Recent Sessions */}
        <div className="space-y-6">
          <h2 className="text-2xl font-bold flex items-center gap-3">
            <Dumbbell className="text-[#00d4ff]" />
            {isRtl ? 'الجلسات الأخيرة' : 'Recent Sessions'}
          </h2>
          <div className="space-y-4 max-h-[600px] overflow-y-auto pr-2 no-scrollbar">
            <AnimatePresence mode="popLayout">
              {workouts.map((workout) => (
                <motion.div
                  key={workout.id}
                  layout
                  initial={{ opacity: 0, x: 20 }}
                  animate={{ opacity: 1, x: 0 }}
                  exit={{ opacity: 0, x: -20 }}
                  className="bg-[#0a0a0a] border border-white/5 p-6 rounded-3xl group hover:border-[#ff6b35]/30 transition-all"
                >
                  <div className="flex items-center justify-between mb-4">
                    <span className="text-xs font-bold text-gray-500 uppercase tracking-widest">{workout.date}</span>
                    <div className="flex gap-2">
                      <button 
                        onClick={() => toggleComplete(workout)}
                        className={`p-2 rounded-lg transition-all ${workout.completed ? 'bg-green-500 text-white' : 'bg-white/5 text-gray-500 hover:text-green-500'}`}
                      >
                        <CheckCircle2 size={18} />
                      </button>
                      <button 
                        onClick={() => deleteWorkout(workout.id)}
                        className="p-2 bg-white/5 rounded-lg text-gray-500 hover:bg-red-500 hover:text-white transition-all"
                      >
                        <Trash2 size={18} />
                      </button>
                    </div>
                  </div>
                  <h3 className="text-lg font-bold group-hover:text-[#ff6b35] transition-colors">{workout.workoutName}</h3>
                  <p className="text-xs text-gray-500 mt-2">{workout.exercises.length} {isRtl ? 'تمارين' : 'Exercises'}</p>
                </motion.div>
              ))}
            </AnimatePresence>
            {workouts.length === 0 && !loading && (
              <div className="text-center py-20 text-gray-500">
                <CalendarIcon size={48} className="mx-auto mb-4 opacity-20" />
                <p>{isRtl ? 'لا توجد جلسات مجدولة' : 'No scheduled sessions'}</p>
              </div>
            )}
          </div>
        </div>
      </div>
    </div>
  );
};

export default ProgressTracker;
